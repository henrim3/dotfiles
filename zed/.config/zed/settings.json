// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "dock": "right",
    "default_model": {
      "provider": "google",
      "model": "gemini-2.5-flash-lite",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "file_finder": {
    "modal_max_width": "full",
  },
  "hide_mouse": "on_typing_and_movement",
  "soft_wrap": "none",
  "sticky_scroll": {
    "enabled": true,
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
  },
  "outline_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "project_panel": {
    "auto_fold_dirs": false,
    "dock": "right",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": true,
  "icon_theme": "Catppuccin Frappé",
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Palenight Theme",
  },
  "relative_line_numbers": "enabled",
  "cursor_blink": false,
  "cursor_shape": "underline",
  "buffer_font_family": "Hurmit Nerd Font Mono",
  "ui_font_family": "Hurmit Nerd Font Mono",
  "buffer_font_size": 14,
  "ui_font_size": 14.0,
  "show_wrap_guides": true,
  "wrap_guides": [80],
  "use_autoclose": false,
}
