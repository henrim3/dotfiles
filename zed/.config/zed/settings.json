// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diff_view_style": "split",
  "terminal": {
    "copy_on_select": false,
    "toolbar": {
      "breadcrumbs": true,
    },
    "show_count_badge": false,
  },
  "languages": {
    "C++": {
      "format_on_save": "on",
      "tab_size": 2,
    },
  },
  "cli_default_open_behavior": "new_window",
  "collaboration_panel": {
    "dock": "left",
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
    "cursor": {
      "favorite_config_option_values": {
        "model": ["grok-4.5[effort=high,fast=true]", "composer-2.5[fast=true]"],
      },
      "default_config_options": {
        "mode": "ask",
        "model": "composer-2.5[fast=true]",
      },
      "type": "registry",
    },
    "codex-acp": {
      "default_config_options": {
        "mode": "read-only",
      },
      "favorite_config_option_values": {
        "mode": ["read-only"],
      },
      "type": "registry",
    },
  },
  "agent": {
    "dock": "right",
    "default_model": {
      "provider": "openai",
      "model": "gpt-5.2",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "file_finder": {
    "modal_max_width": "full",
  },
  "hide_mouse": "on_typing_and_action",
  "soft_wrap": "editor_width",
  "sticky_scroll": {
    "enabled": true,
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
  },
  "outline_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "project_panel": {
    "auto_fold_dirs": false,
    "dock": "right",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": true,
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Frappé",
    "dark": "Catppuccin Frappé",
  },
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Oldschool QBasic",
  },
  "relative_line_numbers": "enabled",
  "cursor_blink": false,
  "cursor_shape": "underline",

  "buffer_font_family": "Hurmit Nerd Font Mono",
  "ui_font_family": "Hurmit Nerd Font Mono",
  "buffer_font_size": 14,
  "ui_font_size": 14.0,

  // "buffer_font_family": "Print Char 21",
  // "ui_font_family": "Print Char 21",
  // "buffer_font_size": 12,
  // "ui_font_size": 12.0,

  // "buffer_font_family": "Ac437 IBM BIOS",
  // "ui_font_family": "Ac437 IBM BIOS",
  // "buffer_font_size": 12,
  // "ui_font_size": 12.0,

  "show_wrap_guides": true,
  "wrap_guides": [80],
  "use_autoclose": false,
}
