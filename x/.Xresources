! urxvt
URxvt*buffered: true
URxvt*underlineColor: yellow
URxvt*font: xft:JetBrains Mono Nerd Font:size=10, \
            xft:Noto Color Emoji:style=regular:size=10 \
            xft:Hack Nerd Font
URxvt*depth: 32
URxvt*borderless: 1
URxvt*scrollBar: false
URxvt*loginShell: true
URxvt*saveLines: 5000
URxvt*termName: rxvt-unicode
URxvt.geometry: 400x400


! PERL EXTENSIONS
!Urxvt.perl-lib: ~/.urxvt/ext/
URxvt.perl-ext-common: default,matcher,font-size

! url clicking
URxvt.urlLauncher: firefox
URxvt.matcher.button: 1

! change font size
URxvt.keysym.C-equal: font-size:increase
URxvt.keysym.C-minus: font-size:decrease
URxvt.keysym.C-slash: font-size:show

urxvt.transparent: false

! Palenight Xresources palette
!! COLORS

! special
URxvt*foreground:   #bbc5ff
URxvt*background:   [95]#282a36
URxvt*cursorColor:  #bbc5ff

XTerm*foreground: #bbc5ff
XTerm*background: #282a36
XTerm*cursorColor: #bbc5ff

! black
*.color0:       #101010  !! originally #292d3e
*.color8:       #434758

! red
*.color1:       #f07178
*.color9:       #ff8b92

! green
*.color2:       #c3e88d
*.color10:      #ddffa7

! yellow
*.color3:       #ffcb6b
*.color11:      #ffe585

! blue
*.color4:       #82aaff
*.color12:      #9cc4ff

! magenta
*.color5:       #c792ea
*.color13:      #e1acff

! cyan
*.color6:       #89ddff
*.color14:      #a3f7ff

! white
*.color7:       #d0d0d0
*.color15:      #ffffff

